{
  "name": "bav-react-ui",
  "version": "0.2.2",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bavirtual/bav-react-ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/bav-ui.cjs",
  "module": "./dist/bav-ui.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/bav-ui.mjs",
      "require": "./dist/bav-ui.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "playground:dev": "cd playground && bun run dev",
    "playground:build": "cd playground && bun run build",
    "playground:build:docs": "cd playground && bun run build && rm -rf ../docs && mv storybook-static ../docs",
    "playground:deploy:gh-pages": "npm run playground:build:docs && bunx gh-pages -d docs"
  },
  "dependencies": {
    "react-feather": "^2.0.10",
    "zustand": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^17.7.0",
    "path": "^0.12.7",
    "prettier": "^3.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^5.0.2",
    "zustand": "^5.0.13"
  }
}
